  "license": "ISC",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "install": "^0.13.0",
    "prettier": "^2.3.0"
  },
  "overrides": {
    "json-with-bigint": "^3.5.8"
  }
}
